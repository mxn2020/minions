{
  "name": "minions-sdk",
  "version": "0.2.5",
  "description": "Framework-agnostic core library for the Minions structured object system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mxn2020/minions"
  },
  "homepage": "https://github.com/mxn2020/minions",
  "keywords": [
    "ai",
    "agents",
    "structured-objects",
    "schema",
    "minions"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/node.js",
      "types": "./dist/node.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node --experimental-modules scripts/gen-version.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "docs": "typedoc",
    "dev": "echo 'no dev'",
    "stop": "pkill -f 'vite.*core' || true"
  },
  "peerDependencies": {
    "@neondatabase/serverless": ">=0.9.0",
    "@supabase/supabase-js": ">=2.0.0",
    "convex": ">=1.0.0",
    "ioredis": ">=5.0.0",
    "sql.js": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "convex": {
      "optional": true
    },
    "@supabase/supabase-js": {
      "optional": true
    },
    "sql.js": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "@neondatabase/serverless": {
      "optional": true
    }
  },
  "devDependencies": {
    "sql.js": "^1.14.1",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "author": "Mehdi Nabhani <mehdi@the-mehdi.com> (https://the-mehdi.com)"
}